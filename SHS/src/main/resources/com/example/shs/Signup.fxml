<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shs.SignupController">

    <!-- Left Panel with Image and Branding -->
    <left>
        <VBox alignment="CENTER" prefHeight="700.0" prefWidth="400.0" style="-fx-background-color: linear-gradient(to bottom, #2d5016, #4a6741);">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <!-- University Image -->
                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 3);">
                    <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                    </padding>
                    <children>
                        <ImageView fitHeight="220.0" fitWidth="320.0" preserveRatio="true" style="-fx-background-radius: 12;">
                            <image>
                                <Image url="@Punjab_University.jpg" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>

                <!-- System Title -->
                <VBox alignment="CENTER" spacing="0.0" style="-fx-background-color: rgba(45, 80, 22, 0.8); -fx-background-radius: 8; -fx-padding: 20;">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                    <children>
                        <Label text="STUDENT" textFill="WHITE">
                            <font>
                                <Font name="Arial Black" size="22.0" />
                            </font>
                        </Label>
                        <Label text="HELPING" textFill="WHITE">
                            <font>
                                <Font name="Arial Black" size="22.0" />
                            </font>
                        </Label>
                        <Label text="SYSTEM" textFill="WHITE">
                            <font>
                                <Font name="Arial Black" size="22.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <!-- Subtitle -->
                <Label text="Join Us and Find Your Perfect University Path" textFill="#c8d5c8">
                    <font>
                        <Font name="Arial" size="12.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="12.0" />
                    </VBox.margin>
                </Label>
            </children>
        </VBox>
    </left>

    <!-- Right Panel with Signup Form -->
    <center>
        <VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="500.0" spacing="12.0" style="-fx-background-color: #ffffff;">
            <padding>
                <Insets bottom="15.0" left="35.0" right="35.0" top="20.0" />
            </padding>
            <children>
                <!-- Signup Page Title -->
                <VBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Label text="Create Account" textFill="#2c3e50">
                            <font>
                                <Font name="Arial Bold" size="26.0" />
                            </font>
                        </Label>
                        <Label text="Join us today! Fill in your details to get started." textFill="#7f8c8d">
                            <font>
                                <Font name="Arial" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <!-- Signup Form -->
                <VBox alignment="CENTER" maxWidth="380.0" spacing="12.0">
                    <children>
                        <!-- Full Name Field -->
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Full Name" textFill="#34495e">
                                    <font>
                                        <Font name="Arial Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="fullNameField" prefWidth="380.0" promptText="Enter your full name" style="-fx-padding: 8; -fx-font-size: 12; -fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-prompt-text-fill: #6c757d;" />
                            </children>
                        </VBox>

                        <!-- Email Field -->
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Email Address" textFill="#34495e">
                                    <font>
                                        <Font name="Arial Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="emailField" prefWidth="380.0" promptText="Enter your email address" style="-fx-padding: 8; -fx-font-size: 12; -fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-prompt-text-fill: #6c757d;" />
                            </children>
                        </VBox>

                        <!-- Username Field -->
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Username" textFill="#34495e">
                                    <font>
                                        <Font name="Arial Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="usernameField" prefWidth="380.0" promptText="Choose a username" style="-fx-padding: 8; -fx-font-size: 12; -fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-prompt-text-fill: #6c757d;" />
                            </children>
                        </VBox>

                        <!-- Password Field -->
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Password" textFill="#34495e">
                                    <font>
                                        <Font name="Arial Bold" size="12.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="passwordField" prefWidth="380.0" promptText="Create a password" style="-fx-padding: 8; -fx-font-size: 12; -fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-prompt-text-fill: #6c757d;" />
                            </children>
                        </VBox>

                        <!-- Confirm Password Field -->
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Confirm Password" textFill="#34495e">
                                    <font>
                                        <Font name="Arial Bold" size="12.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="confirmPasswordField" prefWidth="380.0" promptText="Confirm your password" style="-fx-padding: 8; -fx-font-size: 12; -fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-prompt-text-fill: #6c757d;" />
                            </children>
                        </VBox>

                        <!-- Terms Agreement Checkbox -->
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <CheckBox fx:id="termsCheckBox" text="I agree to the Terms of Service and Privacy Policy" textFill="#6c757d">
                                    <font>
                                        <Font name="Arial" size="10.0" />
                                    </font>
                                </CheckBox>
                            </children>
                        </HBox>

                        <!-- Signup and Back Buttons -->
                        <VBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Button fx:id="signupButton" onAction="#handleSignup" prefHeight="38.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to right, #27ae60, #2ecc71); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 4, 0, 0, 2);" text="Create Account" />

                                <Button fx:id="backButton" onAction="#handleBack" prefHeight="38.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to right, #95a5a6, #7f8c8d); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 4, 0, 0, 2);" text="Back to Login" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Footer -->
                <Label text="© 2025 Student Helping System. All rights reserved." textFill="#95a5a6">
                    <font>
                        <Font name="Arial" size="9.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </center>

</BorderPane>