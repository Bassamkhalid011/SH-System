<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shs.LoginController">

    <!-- Left Panel with Image and Branding -->
    <left>
        <VBox alignment="CENTER" prefHeight="700.0" prefWidth="400.0" style="-fx-background-color: linear-gradient(to bottom, #2d5016, #4a6741);">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <!-- University Image -->
                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 3);">
                    <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                    </padding>
                    <children>
                        <ImageView fitHeight="220.0" fitWidth="320.0" preserveRatio="true" style="-fx-background-radius: 12;">
                            <image>
                                <Image url="@Punjab_University.jpg" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>

                <!-- System Title -->
                <VBox alignment="CENTER" spacing="0.0" style="-fx-background-color: rgba(45, 80, 22, 0.8); -fx-background-radius: 8; -fx-padding: 20;">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                    <children>
                        <Label text="STUDENT" textFill="WHITE">
                            <font>
                                <Font name="Arial Black" size="22.0" />
                            </font>
                        </Label>
                        <Label text="HELPING" textFill="WHITE">
                            <font>
                                <Font name="Arial Black" size="22.0" />
                            </font>
                        </Label>
                        <Label text="SYSTEM" textFill="WHITE">
                            <font>
                                <Font name="Arial Black" size="22.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <!-- Subtitle -->
                <Label text="Find Your Perfect University Path" textFill="#c8d5c8">
                    <font>
                        <Font name="Arial" size="12.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="12.0" />
                    </VBox.margin>
                </Label>
            </children>
        </VBox>
    </left>

    <!-- Right Panel with Login Form -->
    <center>
        <VBox alignment="CENTER" prefHeight="700.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: #ffffff;">
            <padding>
                <Insets bottom="25.0" left="35.0" right="35.0" top="25.0" />
            </padding>
            <children>
                <!-- Login Page Title -->
                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Label text="Login Page" textFill="#2c3e50">
                            <font>
                                <Font name="Arial Bold" size="26.0" />
                            </font>
                        </Label>
                        <Label text="Welcome back! Please login to your account." textFill="#7f8c8d">
                            <font>
                                <Font name="Arial" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <!-- Login Form -->
                <VBox alignment="CENTER" maxWidth="380.0" spacing="16.0">
                    <children>
                        <!-- Username Field -->
                        <VBox spacing="6.0">
                            <children>
                                <Label text="Username" textFill="#34495e">
                                    <font>
                                        <Font name="Arial Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="usernameField" prefWidth="380.0" promptText="Enter your username" style="-fx-padding: 10; -fx-font-size: 12; -fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-prompt-text-fill: #6c757d;" />
                            </children>
                        </VBox>

                        <!-- Password Field -->
                        <VBox spacing="6.0">
                            <children>
                                <Label text="Password" textFill="#34495e">
                                    <font>
                                        <Font name="Arial Bold" size="12.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="passwordField" prefWidth="380.0" promptText="Enter your password" style="-fx-padding: 10; -fx-font-size: 12; -fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-prompt-text-fill: #6c757d;" />
                            </children>
                        </VBox>

                        <!-- Remember Me Checkbox -->
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <CheckBox fx:id="rememberMeCheckBox" text="Remember me" textFill="#6c757d">
                                    <font>
                                        <Font name="Arial" size="10.0" />
                                    </font>
                                </CheckBox>
                            </children>
                        </HBox>

                        <!-- Login and Sign Up Buttons -->
                        <VBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Button fx:id="loginButton" onAction="#handleLogin" prefHeight="38.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to right, #27ae60, #2ecc71); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 4, 0, 0, 2);" text="Login" />

                                <Button fx:id="signupButton" onAction="#handleSignup" prefHeight="38.0" prefWidth="380.0" style="-fx-background-color: linear-gradient(to right, #3498db, #2980b9); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 4, 0, 0, 2);" text="Sign Up" />
                            </children>
                        </VBox>

                        <!-- Forgot Password Link -->
                        <Hyperlink fx:id="forgotPasswordLink" text="Forgot Password?" textFill="#3498db">
                            <font>
                                <Font name="Arial" size="10.0" />
                            </font>
                        </Hyperlink>
                    </children>
                </VBox>

                <!-- Footer -->
                <Label text="© 2025 Student Helping System. All rights reserved." textFill="#95a5a6">
                    <font>
                        <Font name="Arial" size="9.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </center>

</BorderPane>